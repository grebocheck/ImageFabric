# Copy to `.env` (repo root) and edit as needed. All vars use the HFAB_ prefix.

# Foundation mode: run the full pipeline without torch/llama (default true).
# Flip to false in M0 once the Blackwell GPU stack is installed.
HFAB_STUB_MODE=true

# Server
HFAB_HOST=127.0.0.1
HFAB_PORT=8260

# Model locations (override if weights live on another drive)
# HFAB_IMAGE_MODELS_DIR=D:\models\image
# HFAB_LLM_MODELS_DIR=D:\models\llm

# llama.cpp (real mode)
# HFAB_LLAMA_SERVER_BIN=bin\llama\llama-server.exe
# Optional second build selected by the "turbo" llama backend — a
# TurboQuant-patched llama-server that understands the turbo3 / turbo4 cache types.
# HFAB_LLAMA_SERVER_BIN_TURBO=bin\llama-turbo\llama-server.exe
HFAB_LLAMA_NGL=999
HFAB_LLAMA_CTX=8192
# Active llama build: "default" (standard) or "turbo" (TurboQuant). Switchable
# at runtime from the LLM panel; this is just the startup default.
# HFAB_LLAMA_BACKEND=default
# KV-cache quantization preset: f16 | q8_0 | q4_0 | turbo2 | turbo3 | turbo4
# (turbo* require HFAB_LLAMA_BACKEND=turbo).
# HFAB_LLAMA_CONTEXT_TYPE=f16
