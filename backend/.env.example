# Copy to `.env` (repo root) and edit as needed. All vars use the IMGFAB_ prefix.

# Foundation mode: run the full pipeline without torch/llama (default true).
# Flip to false in M0 once the Blackwell GPU stack is installed.
IMGFAB_STUB_MODE=true

# Server
IMGFAB_HOST=127.0.0.1
IMGFAB_PORT=8260

# Model locations (override if weights live on another drive)
# IMGFAB_IMAGE_MODELS_DIR=D:\models\image
# IMGFAB_LLM_MODELS_DIR=D:\models\llm

# llama.cpp (real mode)
# IMGFAB_LLAMA_SERVER_BIN=bin\llama\llama-server.exe
IMGFAB_LLAMA_NGL=999
IMGFAB_LLAMA_CTX=8192
